{
  "name": "python-ai-exam-system",
  "private": true,
  "version": "1.3.0",
  "description": "Python AI Intelligent Exam System",
  "author": "Exam System Team",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dist": "tsc && vite build && electron-builder",
    "postinstall": "node scripts/patch-electron-rebuild.js && node scripts/copy-monaco.mjs && node scripts/copy-pyodide.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@monaco-editor/react": "^4.6.0",
    "@supabase/supabase-js": "^2.45.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.7.5",
    "electron-builder": "^26.5.0",
    "postcss": "^8.4.40",
    "pyodide": "^0.25.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.0",
    "vite": "^7.3.1"
  },
  "overrides": {
    "tar": "^7.5.4"
  },
  "build": {
    "appId": "com.exam.system",
    "icon": "app_icon.ico",
    "productName": "Python智能考试系统",
    "artifactName": "PythonExamSystem-${version}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/app_icon.ico",
        "to": "external-sources/app_icon.ico"
      },
      {
        "from": "build/setup_icon.ico",
        "to": "external-sources/setup_icon.ico"
      },
      {
        "from": "build/uninstall_icon.ico",
        "to": "external-sources/uninstall_icon.ico"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "app_icon.ico"
    },
    "nsis": {
      "installerIcon": "setup_icon.ico",
      "uninstallerIcon": "uninstall_icon.ico",
      "installerHeaderIcon": "setup_icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/app_icon.icns"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "auricxchu",
      "repo": "Python-AI-Exam-System-CDP"
    }
  }
}
