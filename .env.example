# AI Service Configuration
# 请配置以下至少一个 API Key

# Option 1: Deepseek API (国内网络推荐)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Option 2: Google Gemini API
# 获取地址: https://aistudio.google.com/
API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Option 3: OpenAI API
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Option 4: Qwen (DashScope OpenAI-compatible)
# 获取地址: https://dashscope.aliyuncs.com/
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# Option 5: Moonshot (Kimi)
# 获取地址: https://platform.moonshot.cn/
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-8k

# Cloud Sync (Supabase) - Optional / 可选配置
SUPABASE_URL=
SUPABASE_KEY=
